# Database — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/nestjs_saas_kit

# JWT — generate a strong secret: openssl rand -hex 64
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=15m

# Redis — for token blacklisting (optional)
REDIS_URL=redis://localhost:6379

# Stripe (test mode) — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
# Leave empty for mock mode (accepts unverified JSON payloads locally)
STRIPE_WEBHOOK_SECRET=
# Client URL — used for Stripe success/cancel redirects
CLIENT_URL=http://localhost:3000

# CORS — comma-separated allowed origins (leave empty to allow all origins)
CORS_ORIGIN=http://localhost:3000

# Stripe Price ID — set to your subscription price after creating it in the dashboard
STRIPE_PRICE_ID=
